JFROG_URL=https://your-company.jfrog.io
JFROG_ACCESS_TOKEN=
JFROG_ACCESS_TOKEN_FILE=.secrets/jfrog-token
JFROG_MCP_TRANSPORT=stdio
JFROG_REQUEST_TIMEOUT_SECONDS=20
JFROG_DEFAULT_PAGE_SIZE=50
JFROG_MAX_PAGE_SIZE=200
JFROG_MAX_DEPTH=5
JFROG_MAX_AQL_LIMIT=500
JFROG_CACHE_TTL_SECONDS=60
JFROG_VERIFY_SSL=true
JFROG_CA_BUNDLE=
JFROG_TRUST_ENV=false
JFROG_LOG_LEVEL=INFO
